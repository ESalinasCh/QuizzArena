{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AzureKeyVault": {
    "VaultUri": "https://quiz-dev-kv-uyty.vault.azure.net/"
  },
  "TextGenerationSettings": {
    "Provider": "OpenAiApi",
    "BaseUrl": "https://api.groq.com/openai/v1/"
  },
  "EmbeddingSettings": {
    "Provider": "GoogleGemini",
    "BaseUrl": "https://generativelanguage.googleapis.com/"
  },
  "TranscriptionSettings": {
    "Provider": "Groq",
    "BaseUrl": "https://api.groq.com"
  },
  "Indexing": {
    "EmbeddingModel": "models/gemini-embedding-2",
    "ClassificationModel": "openai/gpt-oss-20b"
  },
  "QuizGeneration": {
    "QuestionEmbeddingModel": "models/gemini-embedding-2",
    "QuizGenerationModel": "openai/gpt-oss-120b",
    "QuizJudgementModel": "openai/gpt-oss-20b"
  }
}
