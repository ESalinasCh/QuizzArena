#!/bin/sh
# ── Husky bootstrap ───────────────────────────────────────────────────────────
_husky="$(dirname "$0")/_/husky.sh"
# shellcheck disable=SC1090
[ -f "$_husky" ] && . "$_husky"
[ "${HUSKY:-1}" = "0" ] && exit 0
[ "${CI:-}" = "true" ]  && exit 0
# ─────────────────────────────────────────────────────────────────────────────

# ── Pre-commit gate (fast checks only) ───────────────────────────────────────
# Runs lightweight checks that give instant feedback before a commit lands.
# Heavier checks (analysis, tests, audit) run at pre-push instead.
#
# Checks:
#   1. Formatting / code style  (just lint)
#   2. Staged secret scan       (just scan-secrets-staged)
#
# Force-skip (strongly discouraged): git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

cd "$(git rev-parse --show-toplevel)" || exit 1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

DIVIDER="════════════════════════════════════════════════════"

if ! command -v just > /dev/null 2>&1; then
    printf "${YELLOW}⚠  'just' not found — pre-commit checks skipped.${RESET}\n"
    printf "   Install: devbox add just  or  https://just.systems\n\n"
    exit 0
fi

FAILED_CHECKS=""
FAILED_COUNT=0
PASSED_COUNT=0

run_check() {
    label="$1"
    task="$2"
    printf "  ${CYAN}%-32s${RESET}" "${label}"
    output=$(just "${task}" 2>&1)
    status=$?
    if [ ${status} -eq 0 ]; then
        printf "${GREEN}✔  passed${RESET}\n"
        PASSED_COUNT=$((PASSED_COUNT + 1))
    else
        printf "${RED}✘  failed${RESET}\n"
        printf "%s\n" "${output}" | sed 's/^/       │ /'
        printf "       └─\n"
        FAILED_CHECKS="${FAILED_CHECKS}\n    • ${label}  (just ${task})"
        FAILED_COUNT=$((FAILED_COUNT + 1))
    fi
}

printf "\n${BOLD}Pre-commit checks${RESET}\n"
printf "${DIVIDER}\n"

run_check "Formatting / code style" "lint"
run_check "Staged secret scan"      "scan-secrets-staged"

printf "${DIVIDER}\n"

TOTAL=$((PASSED_COUNT + FAILED_COUNT))

if [ ${FAILED_COUNT} -gt 0 ]; then
    printf "\n${RED}${BOLD}✘  ${FAILED_COUNT}/${TOTAL} checks failed — commit blocked.${RESET}\n"
    printf "${FAILED_CHECKS}\n"
    printf "\n${BOLD}Fix the issues above, stage your fixes, and retry.${RESET}\n"
    printf "${YELLOW}To bypass (strongly discouraged): git commit --no-verify${RESET}\n\n"
    exit 1
fi

printf "\n${GREEN}${BOLD}✔  ${PASSED_COUNT}/${TOTAL} checks passed — committing.${RESET}\n"
printf "   Full checks (analysis, tests, audit) run at push time.\n\n"
exit 0
