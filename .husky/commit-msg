#!/bin/sh
# ── Husky bootstrap ───────────────────────────────────────────────────────────
# Source husky.sh when available (generated by: dotnet husky install).
# When absent the hook still runs — guards are replicated inline below.
_husky="$(dirname "$0")/_/husky.sh"
# shellcheck disable=SC1090
[ -f "$_husky" ] && . "$_husky"
[ "${HUSKY:-1}" = "0" ] && exit 0   # respect HUSKY=0 (CI / dotnet build)
[ "${CI:-}" = "true" ]  && exit 0   # skip in any CI environment
# ─────────────────────────────────────────────────────────────────────────────

# ── Commit message gate ───────────────────────────────────────────────────────
# Enforces Conventional Commits format on every commit message.
#
#   <type>(<scope>)?: <subject>
#
#   Types: build · chore · ci · docs · feat · fix · perf · refactor · revert · style · test
#   Breaking change: append ! before the colon  →  feat(api)!: remove endpoint
#
# Validation: a single Conventional Commits regex, run inline (see note below).
#
# Force-skip (strongly discouraged): git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

MSG_FILE="$1"

RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

# Validation is a single Conventional Commits regex. Husky.Net's task-runner.json
# runs the *identical* grep, so invoking `dotnet husky run` here adds no extra
# checking — only the dotnet CLI startup cost, and on WSL /mnt/c it can hang
# indefinitely (never returning, so a fallback guarded on its exit code never
# fires). We therefore run the regex inline directly: fast and reliable on every
# platform. CI skips this hook entirely (CI=true guard above).
# ─────────────────────────────────────────────────────────────────────────────

# Same pattern as task-runner.json — kept in sync intentionally.
CC_PATTERN='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([^)]+\))?!?: .{1,}'

if grep -qE "${CC_PATTERN}" "${MSG_FILE}"; then
    exit 0
fi

printf "\n${RED}${BOLD}✘  Commit message does not follow Conventional Commits.${RESET}\n\n"
printf "   Format:  ${BOLD}<type>(<scope>)?: <subject>${RESET}\n\n"
printf "   Types:   build  chore  ci  docs  feat  fix\n"
printf "            perf   refactor  revert  style  test\n\n"
printf "   Examples:\n"
printf "     feat(auth): add JWT refresh token\n"
printf "     fix: correct null reference in IngestionSaga\n"
printf "     chore(ci): update build workflow\n"
printf "     feat(api)!: remove deprecated endpoint\n\n"
printf "${YELLOW}To bypass (strongly discouraged): git commit --no-verify${RESET}\n\n"
exit 1
